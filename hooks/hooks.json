{
  "description": "Starts the ContextSpin daemon at session start so the spinner/statusline has fresh org context.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx --yes contextspin@^0.1.0 start >/dev/null 2>&1; exit 0",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
